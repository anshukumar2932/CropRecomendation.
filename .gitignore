# ======================================
# PYTHON / FLASK BACKEND IGNORE RULES
# ======================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Flask instance folder and caches
instance/
.webassets-cache/
__pycache__/

# Flask log files
*.log
flask*.log
backend/*.log

# Local SQLite database
*.sqlite3
*.sqlite
db.sqlite3
db.sqlite3-journal

# Model checkpoints and large temp data (keep your trained models in model_artifacts)
*.pth
*.pt
*.h5
*.ckpt
!backend/model_artifacts/*.pth
!backend/model_artifacts/*.joblib

# Temporary or generated data
tmp/
temp/
cache/
*.bak
*.tmp

# ======================================
# FRONTEND (React Native / Expo / Node)
# ======================================

# Node modules and dependency caches
frontend/node_modules/
frontend/.expo/
frontend/.expo-shared/
frontend/.expo/*
frontend/yarn.lock
frontend/package-lock.json

# Build artifacts
frontend/build/
frontend/dist/
frontend/web-build/
frontend/.parcel-cache/
frontend/.next/
frontend/.turbo/

# Expo / React Native logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
expo-debug.log
metro-cache/
.expo/
.expo-shared/
*.packager.log
*.reactfile.log
react-native-debugger.log

# Android build files
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/build/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/captures/
frontend/android/.cxx/
frontend/android/.externalNativeBuild/

# iOS build files
frontend/ios/build/
frontend/ios/Pods/
frontend/ios/DerivedData/
frontend/ios/.idea/
frontend/ios/*.xcworkspace
frontend/ios/*.xcuserdata/

# Metro / React Native cache
frontend/.bundle/
frontend/.cache/
frontend/.watchmanconfig
frontend/.vscode/

# ======================================
# GENERAL DEVELOPMENT / IDE / SYSTEM FILES
# ======================================

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# VSCode / JetBrains / Cursor / PyCharm
.vscode/
.idea/
.cursorignore
.cursorindexingignore
*.iml

# macOS / Linux / Windows junk files
.DS_Store
Thumbs.db
*.swp
*.swo
~$

# Python build artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Logs
logs/
log/
npm-debug.log*
*.log
*.out
*.err

# ======================================
# TRAINING NOTEBOOKS & EXPERIMENT FILES
# ======================================

# Ignore auto-saves, checkpoints, and output cells
training-file/.ipynb_checkpoints/
*.ipynb_checkpoints

# ======================================
# PROJECT-SPECIFIC EXCEPTIONS
# ======================================

# Keep essential model artifacts
!backend/model_artifacts/
!backend/model_artifacts/*.joblib
!backend/model_artifacts/*.pth

# ======================================
# END OF FILE
# ======================================
